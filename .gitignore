# macOS / Windows filesystem noise
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
Desktop.ini

# Editor / IDE files
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# Dependencies
node_modules/

# Logs and local diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*_crash_log.txt
disco_scratchpad.txt

# Environment and local secrets
.env
.env.*
!.env.example
!*.env.example
*.local
*.pem
*.key
*.p12
*.pfx

# Build, cache, and coverage output
dist/
dist-ssr/
build/
.vite/
.cache/
coverage/

# Local database / backup artifacts
dump/
*.tar.gz
*.tgz
*.sqlite
*.sqlite3
*.db
*.lock

# Generated repo context dumps
repo_context.txt
v2_repo_context.txt

# Uploaded/generated media files
backend/media/items/original/*
backend/media/items/display/*
backend/media/items/thumb/*
backend/media/items/processed/*
backend/media/boxes/original/*
backend/media/boxes/display/*
backend/media/boxes/thumb/*
backend/media/boxes/processed/*

# Runtime intake staging workspace
/var/intake/_uploads/*
!/var/intake/_uploads/.gitkeep
/var/intake/batches/*
!/var/intake/batches/.gitkeep

# Local frontend scratch space
/frontend/temp/

# Test-generated output
/test/output/

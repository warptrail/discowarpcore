{
  "name": "discowarpcore",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "warptrail",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "install:all": "npm install && cd frontend && npm install",
    "seed": "node backend/scripts/seed.js",
    "seed:all": "node backend/scripts/seed.js --all",
    "seed:boxes:range": "node backend/scripts/seed_boxes_range.js",
    "seed:boxes:700": "node backend/scripts/seed_boxes_range.js --start=700 --count=75",
    "backup:full": "node backend/scripts/backup-full.js",
    "restore:full": "node backend/scripts/restore-full.js",
    "reset": "node backend/scripts/reset.js",
    "reset:hard": "node backend/scripts/reset-hard.js",
    "test:delete-enforcement": "node backend/scripts/test_box_delete_enforcement.js",
    "test:media-cleanup": "node backend/scripts/test_media_cleanup.js",
    "test:event-logging": "node backend/scripts/test_event_logging.js",
    "test:ai-json-import-validation": "node backend/scripts/test_ai_json_import_validation.js",
    "test:media-subsystem-contract": "node --test test/media/mediaSubsystem.contract.test.js",
    "test:media-job-contract": "node --test test/media/mediaJobService.contract.test.js",
    "test:entity-media-contract": "node --test test/media/entityMedia.contract.test.js",
    "test:batch-import-media-contract": "node --test test/media/batchImportedMedia.contract.test.js test/media/batchImportImageService.contract.test.js",
    "intake:create-batch": "node scripts/create_intake_batch.js",
    "intake:build-package": "node scripts/dwc_batch_send.js",
    "intake:tui": "node scripts/intake_tui.js",
    "intake:simple:init": "node scripts/ordered_text_intake.js --init",
    "intake:simple:submit": "node scripts/ordered_text_intake.js --submit",
    "intake:simple:reset": "node scripts/ordered_text_intake.js --reset",
    "intake:text:init": "node scripts/ordered_text_intake.js --init",
    "intake:text:submit": "node scripts/ordered_text_intake.js --submit",
    "intake:text": "node scripts/ordered_text_intake.js --init",
    "intake:ordered": "node scripts/ordered_text_intake.js --submit",
    "intake:preprocess-images": "node scripts/preprocess_vision_images.js",
    "intake:vision": "node scripts/build_vision_intake_batch.js",
    "intake:trash-staging": "node scripts/trash_vision_staging.js",
    "intake:merge-json": "node scripts/merge_inventory_json.js",
    "intake:assign-imagekeys": "node scripts/assign_imagekeys_to_json.js",
    "intake:validate-batch": "node scripts/validate_intake_batch.js",
    "intake:stage-images": "node scripts/stage_imagekey_files.js",
    "deploy:neonazoth": "rsync -avz --delete --exclude 'node_modules/' --exclude 'dist/' --exclude '.git/' --exclude '.vite/' --exclude 'frontend/node_modules/' --exclude 'frontend/dist/' --exclude 'backend/media/' ./ warptrail@neonazoth:~/discowarpcore/",
    "deploy:neonazoth:dry": "rsync -avzn --delete --exclude 'node_modules/' --exclude 'dist/' --exclude '.git/' --exclude '.vite/' --exclude 'frontend/node_modules/' --exclude 'frontend/dist/' --exclude 'backend/media/' ./ warptrail@neonazoth:~/discowarpcore/",
    "install:neonazoth": "ssh warptrail@neonazoth 'cd ~/discowarpcore && npm install && cd frontend && npm install'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "mongoose": "^8.16.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^24.31.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
